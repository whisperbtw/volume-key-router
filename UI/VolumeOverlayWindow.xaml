<Window x:Class="VolumeKeyRouter.VolumeOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="430"
        Height="136"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#F2F4F8">
    <Border Background="#F2121419" CornerRadius="14" Padding="16,14,18,16">
        <DockPanel LastChildFill="True">
            <Border x:Name="ArtworkFrame"
                    DockPanel.Dock="Left"
                    Width="76"
                    Height="76"
                    Background="#2A2F3A"
                    CornerRadius="8"
                    Margin="0,0,14,0"
                    Visibility="Collapsed" />

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="94" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TargetText" Grid.Row="0" Grid.Column="0" Foreground="#B6BECA" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="PercentText" Grid.Row="0" Grid.Column="1" FontSize="24" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" />

            <TextBlock x:Name="DetailText" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Foreground="#F2F4F8" FontSize="13" TextTrimming="CharacterEllipsis" Visibility="Collapsed" Margin="0,0,0,8" />

            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Height="14" VerticalAlignment="Center" Background="#2A2F3A" CornerRadius="3" Padding="2">
                <Grid x:Name="BarTrack">
                    <Border x:Name="BarFill" HorizontalAlignment="Left" Background="#26D07C" CornerRadius="2" />
                </Grid>
            </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
